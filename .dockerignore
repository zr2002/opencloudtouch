# Version Control & CI
.git/
.gitignore
.gitattributes
.github/
.pre-commit-config.yaml

# IDE
.vscode/
.idea/

# Python (not needed in container)
**/__pycache__/
**/*.pyc
**/.pytest_cache/
**/.coverage
htmlcov/
**/*.egg-info/
.venv/
.ruff_cache/

# Node.js (not needed — frontend is pre-built in CI)
**/node_modules/
**/.vite/

# Build & Test Artifacts
# Keep .out/dist/ — pre-built frontend from CI is placed there
.out/coverage/
.out/test-results/
.out/reports/
.out/.ruff_cache/
.out/.pytest_cache/
**/coverage/

# Tests (not needed in production image)
apps/backend/tests/
apps/frontend/tests/
apps/frontend/cypress/
scripts/

# Documentation
*.md
!README.md
!DISCLAIMER.md

# Environment & Config
.env
.env.*
*.local.*
.local/

# Data & Deployment
data-local/
deployment/
*.db
*.db-journal
*.tar
*.img
*.log
