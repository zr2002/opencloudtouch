# OpenCloudTouch Backend Development Configuration
# Copy this file to .env and adjust values
# This file is for LOCAL DEVELOPMENT ONLY (running backend with: python -m opencloudtouch)
# For deployment configuration, see deployment/local/.env.template

# Backend Server Configuration (local dev)
OCT_HOST=0.0.0.0
OCT_PORT=7778
OCT_LOG_LEVEL=DEBUG
OCT_LOG_DIR=./logs
OCT_DB_PATH=./data/oct.db

# Discovery Configuration
OCT_DISCOVERY_ENABLED=true
OCT_DISCOVERY_TIMEOUT=10

# Device Ports (for development/testing)
OCT_DEVICE_HTTP_PORT=8090
OCT_DEVICE_WS_PORT=8080

# Station Descriptor (use your dev machine IP/hostname)
OCT_STATION_DESCRIPTOR_BASE_URL=http://localhost:7778/stations/preset

# Optional: Manual Device IPs (comma-separated)
# OCT_MANUAL_DEVICE_IPS=192.168.1.100,192.168.1.101

# Mock Mode (for testing without real devices)
OCT_MOCK_MODE=false

# ============================================================
# DEPLOYMENT CONFIGURATION (for deploy-to-server.ps1)
# ============================================================

# Remote Server
DEPLOY_HOST=192.168.178.11
DEPLOY_USER=yourusername
DEPLOY_USE_SUDO=false

# Container Configuration
CONTAINER_NAME=opencloudtouch
CONTAINER_TAG=opencloudtouch:latest
CONTAINER_PORT=7777

# Remote Paths (on deployment target)
REMOTE_DATA_PATH=/mnt/tank/applications/opencloudtouch/data
REMOTE_LOG_PATH=/mnt/tank/applications/opencloudtouch/logs
REMOTE_IMAGE_PATH=/tmp

# Local Paths (on dev machine)
LOCAL_DATA_PATH=./deployment/data-local

# ============================================================
# SECRETS (DO NOT COMMIT - add to .env.local instead)
# ============================================================
# SSH_PASSWORD=
# TELEGRAM_TOKEN=
# TELEGRAM_CHAT_ID=
# GITHUB_TOKEN_COPILOT=
